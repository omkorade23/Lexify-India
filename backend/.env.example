# ==============================================================================
# Lexify-India Backend — Environment Variables
# Copy this file to .env and fill in real values before running the server.
# ==============================================================================

# --- Application ---
API_TITLE=Lexify-India API
API_VERSION=1.0.0
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# --- File Upload ---
UPLOAD_DIR=data/uploads
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=.pdf,.jpg,.jpeg,.png

# --- OCR ---
OCR_CONFIDENCE_THRESHOLD=0.6

# --- Vector DB ---
DATABASE_PATH=data/chroma_db
COLLECTION_NAME=legal_documents
DOCUMENT_COLLECTION_NAME=document_chunks
LEGAL_COLLECTION_NAME=legal_knowledge
SIMILARITY_THRESHOLD=0.7
DOCUMENT_SIMILARITY_THRESHOLD=0.40
LEGAL_SIMILARITY_THRESHOLD=0.35
DOCUMENT_TOP_K=5
LEGAL_TOP_K=3

# --- RAG / LLM Agent (Phase 2) ---
# REQUIRED: Set your Gemini API key here
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

EMBEDDING_MODEL=gemini-embedding-001
LLM_MODEL=gemini-2.5-flash
LLM_MAX_TOKENS=1500

# --- Chunking ---
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# --- Data Paths ---
LEGAL_KNOWLEDGE_PATH=data/legal_knowledge_base.json
DOCUMENT_REGISTRY_PATH=data/document_registry.json
